[flake8]
max-line-length = 120

# E221  — multiple spaces before operator (alignment spacing)
# E272  — multiple spaces before keyword (alignment spacing)
# E271  — multiple spaces after keyword (intentional if/elif alignment)
# E701  — multiple statements on one line (colon) → if x: do()
# E128  — continuation line under-indented for visual indent
# E131  — continuation line unaligned for block comment
# E127  — continuation line over-indented for visual indent
# E261  — at least two spaces before inline comment
# E231  — missing whitespace after ',' or ':'
# E302  — expected 2 blank lines, found fewer (between top-level defs)
# E702  — multiple statements on one line (semicolon) → x=1; y=2
# E225  — missing whitespace around operator → x=1 vs x = 1
# E301  — expected 1 blank line before nested definition
# E305  — expected 2 blank lines after class or function definition
# E401  — multiple imports on one line → import os, sys

extend-ignore = E221,E272,E271,E701,E128,E131,E127,E261,E231,E302,E702,E225,E301,E305,E401